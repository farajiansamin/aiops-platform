# ===========================================
# AIOps Platform - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
# At minimum, you need ONE LLM provider key and a database URL.

# --- LLM Provider (at least one required) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-...
# User token is required for Slack message search (search.messages API)
SLACK_USER_TOKEN=xoxp-...
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=xapp-...
# Comma-separated Slack channel IDs for the #infrastructure channel(s)
SLACK_INFRA_CHANNEL_IDS=C0123ABC

# --- Rootly ---
ROOTLY_API_TOKEN=
ROOTLY_BASE_URL=https://api.rootly.com

# --- JIRA / Atlassian ---
ATLASSIAN_HOST=yourcompany.atlassian.net
ATLASSIAN_EMAIL=you@company.com
ATLASSIAN_API_TOKEN=

# --- Confluence (uses same Atlassian creds, optional separate host) ---
CONFLUENCE_HOST=

# --- GitHub ---
GITHUB_TOKEN=ghp_...
GITHUB_ORG=your-org

# --- Database ---
POSTGRES_URL=postgresql://localhost:5432/aiops

# --- Application Database (Read-Only, for Impact Analysis) ---
# Optional: Read-only connection to your application's database
# Used to query impacted users during incidents (Use Case 2)
APP_DATABASE_URL=
APP_DATABASE_SSL=true
# Optional: Custom SQL query for impact analysis. Receives $1=start_time, $2=end_time, $3=services
# APP_IMPACT_QUERY=

# --- NextAuth ---
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
